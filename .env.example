# --- Telegram API credentials (from https://my.telegram.org) ---
TG_API_ID=1234567
TG_API_HASH=abcdef1234567890abcdef1234567890

# --- Work chat ID (run list_chats.py to find it) ---
# Example for supergroup: -1001234567890
TG_CHAT_ID=-1001234567890

# --- Widget auth token (any long random string, e.g. `openssl rand -hex 32`) ---
WIDGET_TOKEN=change_me_to_a_long_random_string

# --- Optional: where to persist status and session ---
STATE_FILE=state.json
SESSION_NAME=leads_status

# Port is set by Render automatically; override only for local dev
PORT=8000
